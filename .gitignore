# =============================================================================
# DS4300 HW1 submission filter
#
# Anything matched here is NOT part of the submission. The submission is
# whatever `git ls-files` shows after this file takes effect, which should be:
#
#   pom.xml
#   .gitignore
#   src/main/java/twitter/**/*.java
#   src/main/resources/db.properties.example
#   report/report.pdf
#
# Per the assignment: "Do not zip up your code or provide links to a
# repository." Upload the tracked files (preserving folder structure)
# directly to Canvas, not as a GitHub URL.
# =============================================================================

# --- Build artifacts ---
target/
*.class

# --- Secrets / local config ---
# Contains MySQL credentials. Submit db.properties.example instead.
src/main/resources/db.properties

# --- Data (per assignment: "You do not need to submit the data") ---
hw1_data/

# --- Benchmark output ---
bench-logs/

# --- Staging copies (don't commit duplicate submission folders) ---
submission/
submit/

# --- AI-collab internal docs (not part of the submission) ---
plan.md
AGENTS.md
CLAUDE.md

# --- Source materials (do not re-upload the assignment file) ---
twitter_rdb_v2.pdf

# --- LaTeX (keep only the .pdf; source and build artifacts excluded) ---
report/*.tex
report/*.aux
report/*.log
report/*.out
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
report/*.synctex(busy)
report/*.toc
report/*.bbl
report/*.blg

# --- Java/Maven logs ---
*.log

# --- IDE / editor ---
.idea/
*.iml
*.iws
.vscode/
.classpath
.project
.settings/
.cursor/

# --- OS junk ---
.DS_Store
Thumbs.db
